{
  "name": "workos-bulk-org-create",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Bulk-create, update, verify, and delete WorkOS organizations from a CSV/JSONL, with rate limiting and retries.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "tsx src/create-orgs.ts",
    "create": "tsx src/create-orgs.ts",
    "delete": "tsx src/delete-orgs.ts",
    "verify": "tsx src/verify-orgs.ts",
    "generate-fixture": "tsx scripts/generate-fixture.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@workos-inc/node": "^7.45.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
